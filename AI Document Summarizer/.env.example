# ── Production Environment Configuration Template ──────────────────────────
# Copy this file to `.env` in the root directory before running docker-compose up

# ── General Server & Ports ───────────────────────────────────────────────
PORT_HTTP=8080
SESSION_SECRET=replace-with-a-secure-random-secret-key-min-32-chars
FRONTEND_URL=http://localhost:8080
SERVER_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080

# ── Database & Redis ──────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/ai-docs-summarizer
MONGO_TLS=false
REDIS_URI=redis://redis:6379

# ── OAuth Configuration (Google) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── AI API Keys ───────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Gemini API Keys (Rotated automatically by server)
GEMINI_KEY_1=your-gemini-key-1
GEMINI_KEYS_COUNT=1

# ── Payment Gateway (Cashfree) ────────────────────────────────────────────
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
CASHFREE_ENV=PRODUCTION
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret

# ── Email Service (SMTP) ──────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-app-password
EMAIL_FROM="AI Document Summarizer <your-email@gmail.com>"
